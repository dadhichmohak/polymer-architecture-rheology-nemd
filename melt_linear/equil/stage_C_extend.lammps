# ============================================================
# Stage C Extension : Additional Equilibration
#
# Input:
#   output/linear_melt.restart
#
# Purpose:
#   Additional 200k-step safety equilibration
#
# Output:
#   output/linear_melt_extended.restart
#   output/linear_melt_extended.data
#   output/stage_C_monitor_extended.dat
#   output/end_to_end_extended.dat
#   output/traj_equil_extended.lammpstrj
# ============================================================

units           lj
atom_style      bond
boundary        p p p

read_restart    output/linear_melt.restart

# ------------------------------------------------------------
# Force field
# ------------------------------------------------------------

bond_style      fene
bond_coeff      1 30.0 1.5 1.0 1.0

special_bonds   fene

pair_style      lj/cut 1.12246204831
pair_coeff      1 1 1.0 1.0 1.12246204831
pair_modify     shift yes

# ------------------------------------------------------------
# Communication
# ------------------------------------------------------------

comm_modify     cutoff 3.0

neighbor        0.4 bin
neigh_modify    every 1 delay 0 check yes

# ------------------------------------------------------------
# NVT Equilibration
# ------------------------------------------------------------

fix             nvt_equil all nvt temp 1.0 1.0 0.1

timestep        0.005

# ------------------------------------------------------------
# Computes
# ------------------------------------------------------------

compute         gyr all gyration
compute         msd all msd com yes

variable        Rg2 equal c_gyr
variable        msd_com equal c_msd[4]

fix mon all ave/time 1000 1 1000 v_Rg2 v_msd_com file output/stage_C_monitor_extended.dat

# ------------------------------------------------------------
# End-to-end vector (chain 1)
# ------------------------------------------------------------

variable ete_x equal x[1]-x[100]
variable ete_y equal y[1]-y[100]
variable ete_z equal z[1]-z[100]

variable R2 equal v_ete_x*v_ete_x+v_ete_y*v_ete_y+v_ete_z*v_ete_z

fix ete all ave/time 1000 1 1000 v_ete_x v_ete_y v_ete_z v_R2 file output/end_to_end_extended.dat

# ------------------------------------------------------------
# Thermodynamics
# ------------------------------------------------------------

thermo_style custom step temp pe ke etotal press density v_Rg2 v_msd_com
thermo          10000

# ------------------------------------------------------------
# Trajectory
# ------------------------------------------------------------

dump traj all custom 50000 output/traj_equil_extended.lammpstrj id mol type x y z
dump_modify traj sort id

# ------------------------------------------------------------
# Additional Equilibration
# ------------------------------------------------------------

run             200000

# ------------------------------------------------------------
# Save
# ------------------------------------------------------------

write_restart   output/linear_melt_extended.restart
write_data      output/linear_melt_extended.data

print "=== Stage C EXTENDED complete ==="