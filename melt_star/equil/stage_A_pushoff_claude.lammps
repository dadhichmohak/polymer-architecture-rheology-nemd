# ============================================================
# Stage A: Soft push-off
# Input : ../build/star_melt_init.data
# Goal  : Remove overlapping pairs (min dist ~0.3 sigma)
#         using ramped soft potential + nve/limit
# Output: output/pushoff.restart
#         output/pushoff.data
#         output/stage_A_monitor.dat  ← validation data
# ============================================================

units           lj
atom_style      bond
boundary        p p p
# processors      4 1 1

read_data       ../build/star_melt_init.data

# ---- Bond: harmonic during push-off ----
# FENE not used here — bonds at exactly 1.0 sigma,
# sharp bends put 1-3 pairs close, harmonic is safer
bond_style      harmonic
bond_coeff      1 200.0 1.0

# 1-2 excluded, 1-3 and 1-4 INCLUDED in non-bonded
# so the soft potential can push apart near-contact pairs
special_bonds   lj 0.0 1.0 1.0

# ---- Soft pair potential, amplitude ramped 0 -> 100 ----
pair_style      soft 1.12246204831
pair_coeff      1 1 0.0 1.12246204831

variable        soft_amp equal ramp(0.0,100.0)
fix             ramp all adapt 1 pair soft a 1 1 v_soft_amp

# ---- nve/limit: caps displacement to 0.05 sigma/step ----
fix             push all nve/limit 0.05
timestep        0.001

# ---- Monitoring ----
# Track: PE, pressure, temp every 1000 steps
# PE should drop monotonically as overlaps are removed
variable        pe_val   equal pe
variable        pres_val equal press

fix             mon all ave/time 100 10 1000 &
                v_pe_val v_pres_val &
                file output/stage_A_monitor.dat &
                title1 "# step PE press"

thermo_style    custom step temp pe ke etotal press
thermo          2000

# ---- A1: Ramp soft potential — 50,000 steps = 50 tau ----
run             50000

unfix           ramp
unfix           push

# ---- A2: NVT with soft held at A=100 — 50,000 steps ----
# Distribute kinetic energy properly at T=1
velocity        all create 1.0 54321 rot yes dist gaussian
fix             nvt_soft all nvt temp 1.0 1.0 0.1
timestep        0.005
run             50000
unfix           nvt_soft

# ---- Save ----
write_restart   output/pushoff.restart
write_data      output/pushoff.data

print "=== Stage A complete ==="